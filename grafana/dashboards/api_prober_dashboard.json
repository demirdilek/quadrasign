  "liveNow": false,
  "panels": [
    {
      "title": "Latency (99th Percentile)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_prober_latency_seconds_bucket[5m])) by (le, target))",
          "legendFormat": "{{target}} (p99)"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" }, "unit": "s" }
      }
    },
    {
      "title": "Traffic (Probe Rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(api_prober_traffic_total[5m])) by (target)",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" }, "unit": "reqps" }
      }
    },
    {
      "title": "Errors (Failed Probes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_prober_errors_total[5m])) by (target, status_code)",
          "legendFormat": "{{target}} - Status {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" }, "unit": "none" }
      }
    },
    {
      "title": "Saturation (Active Workers)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "api_prober_saturation_active_workers",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" }, "unit": "none" }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["sre", "network"],
  "time": { "from": "now-15m", "to": "now" },
